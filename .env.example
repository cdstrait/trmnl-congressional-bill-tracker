# Congress.gov API key — register free at https://api.data.gov/signup/
CONGRESS_API_KEY=your_api_key_here

# TRMNL webhook URL — from your Private Plugin in the TRMNL dashboard
TRMNL_WEBHOOK_URL=https://usetrmnl.com/api/custom_plugins/your-plugin-uuid

# How often to check for updates (in seconds). Default: 3600 (1 hour)
UPDATE_INTERVAL=3600
